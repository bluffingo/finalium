<button
    class="button {{ user.info.following ? 'button-default' : 'button-follow' }} button-small button-follow"
    data-user-id="{{ user.id }}"
    data-following="{{ user.info.following ? '1' : '0' }}"
>
    <span class="follow-label">{{ localize('follow') }}</span>
    <span class="followed-label">{{ localize('followed') }}</span>
    <span class="unfollow-label">{{ localize('unfollow') }}</span>
</button>
