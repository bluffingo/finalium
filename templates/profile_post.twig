{% extends "_layout_profile.twig" %}

{% set show_related_channels = false %}

{% set title = data.title %}

{% set selected_tab = "journals" %}

{% block script %}
    <script>
        comment_location_type = 'journal';
        comment_location_id = '{{ data.int_id }}';
    </script>
{% endblock %}

{% block profile_content %}
	<div class="card">
		<div class="card-has-padding">
			<h1>{{ data.title }}</h1>
			{{ data.contents | markdown_user_written(true) }}
		</div>
	</div>
	{% include "components/comment-box.twig" %}
{% endblock %}