{% extends "_layout_profile.twig" %}

{% if show_incomplete_features %}
{% set show_related_channels = true %}
{% endif %}

{% set profile_picture = profile_picture(data.id) %}
{% set banner_picture = profile_banner(data.id) %}

{% set title = data.username %}

{% set selected_tab = "comments" %}

{% block script %}
    <script>
        comment_location_type = 'profile';
        comment_location_id = '{{ data.id }}';
    </script>
{% endblock %}

{% block profile_content %}
    {% include "components/comment-box.twig" %}
{% endblock %}